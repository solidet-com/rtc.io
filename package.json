{
	"name": "rtc.io",
	"version": "1.0.0",
	"description": "WebRTC + socket.io components",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"types": "dist/cjs/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/esm/index.js",
			"require": "./dist/cjs/index.js",
			"types": "./dist/cjs/index.d.ts"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"keywords": [
		"webrtc",
		"rtc.io",
		"signalling server",
		"websocket",
		"realtime",
		"framework",
		"tcp",
		"events",
		"socket",
		"io"
	],
	"scripts": {
		"build": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json"
	},
	"dependencies": {
		"socket.io-client": "^4.7.4",
		"uuid": "^11.1.0"
	},
	"devDependencies": {
		"@types/node": "^16.11.7",
		"prettier": "^3.0.3",
		"socket.io": "^4.7.4",
		"tsc": "^2.0.4",
		"typescript": "^5.8.2"
	}
}
